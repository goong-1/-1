<?xml version="1.0"?>
<robot name="tracking_robot">

  <!-- 1. 가상의 기준점 (바닥면) -->
  <link name="base_footprint"/>

  <!-- 로봇 본체와 바닥 기준점 연결 -->
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.035" rpy="0 0 0"/> <!-- 바닥에서 3.5cm 띄움 (바퀴 반경 고려) -->
  </joint>

  <!-- 2. 로봇 몸체 (파란색 상자) -->
  <link name="base_link">
    <visual>
      <geometry><box size="0.19 0.17 0.05"/></geometry> <!-- 가로 19cm, 세로 17cm, 높이 5cm -->
      <material name="blue"><color rgba="0 0 1 1"/></material>
    </visual>
    <collision> <!-- 충돌 계산용 물리 형태 -->
      <geometry><box size="0.19 0.17 0.05"/></geometry>
    </collision>
    <inertial>
    <origin xyz="0.05 0 -0.05" rpy="0 0 0"/> 
    <mass value="0.261"/>
    <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.009" iyz="0" izz="0.004"/>
  </inertial>
</link>

  <!-- 3. 왼쪽 바퀴 -->
  <link name="left_wheel">
    <visual><geometry><cylinder length="0.02" radius="0.035"/></geometry></visual> <!-- 반경 3.5cm, 두께 2cm 원통 -->
    <collision>
      <geometry><cylinder length="0.02" radius="0.035"/></geometry>
      <surface>
        <friction>
          <ode><mu>0.5</mu><mu2>0.5</mu2></ode> <!-- 마찰력 설정 (미끄러짐 방지) -->
        </friction>
      </surface>
    </collision>
    <inertial><mass value="0.0825"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>

  <!-- 왼쪽 바퀴 회전 관절 -->
  <joint name="left_wheel_joint" type="continuous"> <!-- 무한 회전 가능 -->
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0.05 0.105 -0.01" rpy="-1.5708 0 0"/> <!-- 몸체 기준 왼쪽 배치, 실린더 방향을 위해 90도 회전 -->
    <axis xyz="0 0 1"/> <!-- 회전 축 -->
  </joint>

  <!-- 4. 오른쪽 바퀴 (왼쪽과 대칭) -->
  <link name="right_wheel">
    <visual><geometry><cylinder length="0.02" radius="0.035"/></geometry></visual>
    <collision>
      <geometry><cylinder length="0.02" radius="0.035"/></geometry>
      <surface><friction><ode><mu>0.5</mu><mu2>0.5</mu2></ode></friction></surface>
    </collision>
    <inertial><mass value="0.0825"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>

  <!-- 오른쪽 바퀴 회전 관절 -->
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0.05 -0.105 -0.01" rpy="-1.5708 0 0"/> <!-- 몸체 기준 오른쪽 배치 -->
    <axis xyz="0 0 1"/>
  </joint>

  <!-- 5. 캐스터 바퀴 (보조 바퀴 - 균형 잡기용) -->
  <link name="caster_wheel">
    <visual><geometry><sphere radius="0.02"/></geometry></visual>
    <collision>
      <geometry><sphere radius="0.02"/></geometry>
      <surface>
        <friction>
          <ode><mu>0.0</mu><mu2>0.0</mu2></ode>
        </friction>
      </surface>
    </collision>
    <inertial><mass value="0.01"/><inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/></inertial>
  </link>

  <!-- 캐스터 바퀴 고정 관절 -->
  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="-0.08 0 -0.025"/> <!-- 몸체 뒤쪽 중앙 아래에 배치 -->
  </joint>

  <!-- 6. Gazebo 시뮬레이션 제어 플러그인 -->
  <gazebo>
    <!-- 차동 주행 제어기 (바퀴 구동 시스템) -->
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.21</wheel_separation> <!-- 양쪽 바퀴 사이 거리 21cm -->
      <wheel_radius>0.035</wheel_radius> <!-- 바퀴 반경 3.5cm -->
      <!--<max_linear_acceleration>0.5</max_linear_acceleration> 가속도 제한--> 
      <!--<max_linear_deceleration>0.5</max_linear_deceleration> 감속도 제한-->
      <!--<max_angular_acceleration>1.0</max_angular_acceleration> 가속도 제한-->
      <cmd_vel_timeout>0.1</cmd_vel_timeout> <!-- 명령 시간 초과 (0.1초) -->
      <frame_id>odom</frame_id>
    </plugin>

    <!-- 관절 상태 정보를 시뮬레이션에 전달 -->
    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher"/>
  </gazebo>
</robot>
